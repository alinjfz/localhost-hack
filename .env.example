# Local LLM — via Ollama (default) or Exo Labs
LLM_PROVIDER=ollama          # "ollama" | "exo"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b     # small enough for CPU

# Exo Labs (if using distributed inference across devices)
EXO_BASE_URL=http://localhost:52415

# Cognee memory backend (local by default, no cloud needed)
COGNEE_LLM_PROVIDER=ollama
COGNEE_EMBEDDING_PROVIDER=ollama
COGNEE_EMBEDDING_MODEL=nomic-embed-text

# Overmind trace collector (optional, set to local endpoint)
OVERMIND_ENABLED=false
OVERMIND_ENDPOINT=http://localhost:8080/traces

# Agent identity
AGENT_NAME=LocalMind
AGENT_DATA_DIR=./data
